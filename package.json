{
  "name": "allsvenskan-tipset",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vite": "vite",
    "dev:api": "vercel dev",
    "dev:full": "concurrently -k -n api,web -c cyan,green \"npm:dev:api\" \"npm:dev\"",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:docker:up": "docker compose -f docker-compose.local.yml up -d postgres",
    "db:docker:down": "docker compose -f docker-compose.local.yml down",
    "db:init:local": "node --import tsx server/services/init-local-db.ts",
    "db:seed:local-history": "node --import tsx server/services/seed-local-history.ts",
    "db:seed:docker": "DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54329/allsvenskan_tipset npm run db:seed:local-history",
    "db:setup:docker": "DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54329/allsvenskan_tipset npm run db:init:local && DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54329/allsvenskan_tipset npm run db:seed:local-history",
    "sync:manual": "node --import tsx server/services/run-manual-sync.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.96.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.7.0",
    "postgres": "^3.4.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.7.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vercel": "^50.40.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.3"
  }
}
